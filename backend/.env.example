# ===========================================
# LINER NOTES - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your API keys
# Most sources work without API keys (via scraping)
# but having keys improves reliability and rate limits

# -------------------------------------------
# SPOTIFY (Recommended - OAuth)
# -------------------------------------------
# Get credentials at: https://developer.spotify.com/dashboard
# 1. Create a new app
# 2. Add redirect URI: http://localhost:8000/api/auth/spotify/callback
# 3. Copy Client ID and Client Secret below
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Base URL for OAuth redirects (optional, auto-detected)
# Set this if running behind a proxy or in production
# BASE_URL=http://localhost:8000

# -------------------------------------------
# TIDAL & QOBUZ (Alternative services)
# -------------------------------------------
# Tidal (required for Tidal playback)
TIDAL_USERNAME=
TIDAL_PASSWORD=

# Qobuz (required for Qobuz playback)  
QOBUZ_USERNAME=
QOBUZ_PASSWORD=

# -------------------------------------------
# DATA SOURCE API KEYS (all optional)
# -------------------------------------------

# Groq - For AI-generated liner notes (free tier, recommended)
# Get key at: https://console.groq.com
GROQ_API_KEY=

# OpenAI - Alternative for AI insights
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Last.fm - For listening stats and similar artists
# Get key at: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Genius - For lyrics and annotations
# Get key at: https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=

# Discogs - For vinyl releases and credits
# Get token at: https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# Setlist.fm - For concert setlists
# Get key at: https://api.setlist.fm/docs/1.0/index.html
SETLISTFM_API_KEY=

# YouTube - For music videos and interviews
# Get key at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Spotify - For audio features (metadata only, not playback)
# Get credentials at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# SerpAPI - For Google search results
# Get key at: https://serpapi.com/
SERPAPI_KEY=

# -------------------------------------------
# SOURCES THAT DON'T REQUIRE API KEYS
# -------------------------------------------
# These work out of the box via web scraping:
# - Wikipedia (uses wikipedia-api library)
# - AllMusic (web scraping)
# - WhoSampled (web scraping)
# - Billboard (web scraping)
# - Reddit (public JSON API)
# - MusicBrainz (free public API)
